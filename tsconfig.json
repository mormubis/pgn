{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "noImplicitAny": false,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist/",
    "resolveJsonModule": true,
    "rootDir": "src/",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext"
  },
  "include": ["src/**/*"]
}
